# Base de datos PostgreSQL (Neon)
# Obtené estos valores en: https://console.neon.tech → tu proyecto → "Connection Details"
DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="genera-un-secreto-aleatorio-aqui"
NEXTAUTH_URL="http://localhost:3000"

# OpenAI API Key (para GPT-4o Vision)
OPENAI_API_KEY="sk-..."
