generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH & MULTI-TENANCY ────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships CompanyMembership[]
  accounts    Account[]
  sessions    Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Company {
  id              String          @id @default(cuid())
  name            String
  rut             String          @unique
  contributorType ContributorType @default(NO_CEDE)
  address         String?
  phone           String?
  email           String?
  defaultCurrency String          @default("UYU")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Memory RPA credentials (password stored AES-256-GCM encrypted)
  memoryEmail             String?
  memoryPasswordEncrypted String?

  memberships CompanyMembership[]
  invoices    Invoice[]
  vendors     Vendor[]
  products    Product[]
  ivaRules    IvaClassificationRule[]
}

model CompanyMembership {
  id        String   @id @default(cuid())
  userId    String
  companyId String
  role      UserRole @default(VIEWER)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

enum UserRole {
  ADMIN
  ACCOUNTANT
  VIEWER
}

enum ContributorType {
  MONOTRIBUTISTA
  NO_CEDE
  CEDE
}

// ─── VENDORS / PROVEEDORES ───────────────────────────────────────

model Vendor {
  id              String           @id @default(cuid())
  companyId       String
  name            String
  rut             String
  address         String?
  phone           String?
  email           String?
  contributorType ContributorType?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  products Product[]

  @@unique([companyId, rut])
  @@index([companyId])
}

// ─── INVOICES ────────────────────────────────────────────────────

model Invoice {
  id        String @id @default(cuid())
  companyId String
  vendorId  String?

  fileUrl       String
  fileName      String
  fileType      String
  fileSizeBytes Int?

  status          InvoiceStatus @default(PENDING)
  extractionRaw   Json?
  extractionError String?
  confidence      Float?

  invoiceType   InvoiceType?
  invoiceNumber String?
  invoiceDate   DateTime?
  dueDate       DateTime?
  vendorName    String?
  vendorRut     String?
  currency      String       @default("UYU")

  subtotal    Decimal? @db.Decimal(15, 2)
  totalIva    Decimal? @db.Decimal(15, 2)
  totalAmount Decimal? @db.Decimal(15, 2)

  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNotes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor    Vendor?           @relation(fields: [vendorId], references: [id])
  lineItems InvoiceLineItem[]

  @@index([companyId, status])
  @@index([companyId, invoiceDate])
}

model InvoiceLineItem {
  id           String      @id @default(cuid())
  invoiceId    String
  productId    String?
  lineNumber   Int
  description  String
  quantity     Decimal     @db.Decimal(12, 4)
  unitPrice    Decimal     @db.Decimal(15, 2)
  discount     Decimal     @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal     @db.Decimal(15, 2)
  ivaCategory  IvaCategory @default(BASICA)
  ivaRate      Decimal     @db.Decimal(5, 2)
  ivaAmount    Decimal     @db.Decimal(15, 2)
  classifiedBy String      @default("AI")
  matchedBy    String?     // "EXACT" | "ALIAS" | "AI" | null (how product was matched)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
  @@index([productId])
}

enum InvoiceStatus {
  PENDING
  PROCESSING
  EXTRACTED
  REVIEW
  APPROVED
  REJECTED
  ERROR
}

enum InvoiceType {
  FACTURA_A
  FACTURA_B
  FACTURA_C
  FACTURA_E
  TICKET
  NOTA_CREDITO
  NOTA_DEBITO
  RESGUARDO
}

enum IvaCategory {
  BASICA
  MINIMA
  EXPORTACION
  EXONERADO
}

// ─── PRODUCT CATALOG ─────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  companyId   String
  vendorId    String?
  name        String      // Canonical name (from Memory / original system)
  sku         String?
  description String?
  ivaCategory IvaCategory @default(BASICA)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  company   Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vendor    Vendor?              @relation(fields: [vendorId], references: [id])
  lineItems InvoiceLineItem[]
  aliases   ProductAlias[]

  @@unique([companyId, vendorId, name])
  @@index([companyId])
  @@index([vendorId])
}

// Aliases allow mapping different invoice names to the same canonical product.
// E.g., product "Agua Mineral 500ml" in Memory might appear as "AGUA MIN 500" on invoices.
model ProductAlias {
  id        String   @id @default(cuid())
  productId String
  alias     String   // The alternative name as it appears on invoices
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, alias])
  @@index([alias])
}

// ─── IVA CLASSIFICATION RULES ────────────────────────────────────

model IvaClassificationRule {
  id          String      @id @default(cuid())
  companyId   String?
  keyword     String
  ivaCategory IvaCategory
  priority    Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([keyword])
}
